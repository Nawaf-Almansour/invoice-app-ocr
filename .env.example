# =====================
# NestJS API
# =====================
NODE_ENV=development
PORT=3000
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/invoice_ocr
REDIS_HOST=localhost
REDIS_PORT=6379
OCR_WORKER_URL=http://localhost:8000
UPLOAD_DIR=./uploads
MAX_UPLOAD_SIZE_MB=20
DB_SYNC=true
STORAGE_DRIVER=local
# STORAGE_DRIVER=s3  # (not yet implemented)

# =====================
# React Web
# =====================
VITE_API_URL=http://localhost:3000
VITE_API_BASE_URL=http://localhost:3000/api/v1

# =====================
# Python OCR Worker
# =====================
OCR_DEVICE=cpu
OCR_ENGINE=hybrid
ENABLE_ENHANCED_FALLBACK=false
OCR_MIN_CONFIDENCE=0.75
OCR_ENHANCED_FALLBACK_CONFIDENCE=0.6
OCR_TIMEOUT=120
