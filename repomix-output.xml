<file path="apps/ocr-worker/app/services/ocr_service.py">
import os
import logging
from typing import List, Optional
from pathlib import Path

from app.schemas import OcrLine, OcrLineBox, OcrScanResponse
from app.core.config import settings

logger = logging.getLogger(__name__)

_ocr_engine = None


def _get_engine():
    global _ocr_engine
    if _ocr_engine is None:
        try:
            from paddleocr import PaddleOCR
            _ocr_engine = PaddleOCR(
                lang="ar",
            )
            logger.info("PaddleOCR engine initialized")
        except Exception as e:
            logger.error(f"Failed to initialize PaddleOCR: {e}")
            raise
    return _ocr_engine


def _resolve_path(file_path: str) -> str:
    if os.path.isabs(file_path):
        return file_path
    return os.path.join(settings.UPLOAD_DIR, os.path.basename(file_path))


def _parse_v3_page(page_dict: dict, lines: List[OcrLine]):
    """Parse PaddleOCR v3.x page result (dict with rec_texts, rec_scores, dt_polys)."""
    texts = page_dict.get('rec_texts', [])
    scores = page_dict.get('rec_scores', [])
    polys = page_dict.get('dt_polys', [])
    for i, text in enumerate(texts):
        conf = float(scores[i]) if i < len(scores) else 0.0
        if i < len(polys):
            poly = polys[i]
            x_coords = [float(pt[0]) for pt in poly]
            y_coords = [float(pt[1]) for pt in poly]
            box = OcrLineBox(
                x1=min(x_coords),
                y1=min(y_coords),
                x2=max(x_coords),
                y2=max(y_coords),
            )
        else:
            box = OcrLineBox(x1=0, y1=i * 30, x2=500, y2=i * 30 + 25)
        lines.append(OcrLine(text=str(text), confidence=conf, box=box))


def _paddle_result_to_lines(result) -> List[OcrLine]:
    lines: List[OcrLine] = []
    if not result:
        return lines

    logger.info(f"OCR result type: {type(result).__name__}")

    # PaddleOCR v3.x returns a single dict or a list of dicts (one per page)
    if isinstance(result, dict):
        _parse_v3_page(result, lines)
    elif isinstance(result, list):
        if len(result) > 0 and isinstance(result[0], dict):
            # v3.x: list of page dicts
            for page_dict in result:
                _parse_v3_page(page_dict, lines)
        elif len(result) > 0 and isinstance(result[0], list):
            # Legacy v2.x: list of pages, each page is list of [box, (text, conf)]
            page = result[0]
            for item in page:
                box_coords, (text, confidence) = item
                x_coords = [pt[0] for pt in box_coords]
                y_coords = [pt[1] for pt in box_coords]
                box = OcrLineBox(
                    x1=min(x_coords),
                    y1=min(y_coords),
                    x2=max(x_coords),
                    y2=max(y_coords),
                )
                lines.append(OcrLine(text=text, confidence=float(confidence), box=box))
    else:
        logger.warning(f"Unexpected OCR result type: {type(result)}")

    logger.info(f"Parsed {len(lines)} OCR lines")
    return lines


def _try_vl_fallback(resolved: str) -> Optional[tuple]:
    """
    Attempt PaddleOCR-VL fallback. Returns (markdown_text, doc_json) or None.
    Never raises — any error is caught and logged.
    """
    try:
        from paddleocr import PaddleOCR as _POCR  # noqa: F401
        vl_engine = _POCR(lang="ar", use_doc_orientation_cls=True)
        result = vl_engine.ocr(resolved)
        lines = _paddle_result_to_lines(result)
        md = _build_markdown(lines)
        return md, None
    except ImportError:
        logger.warning("PaddleOCR-VL not available (ImportError)")
        return None
    except Exception as exc:
        logger.warning(f"VL fallback failed: {exc}")
        return None


def run_ocr(
    file_path: str,
    mode: str = "auto",
    language_hints: Optional[List[str]] = None,
) -> OcrScanResponse:
    resolved = _resolve_path(file_path)

    if not os.path.exists(resolved):
        raise FileNotFoundError(f"Invoice file not found: {resolved}")

    effective_engine = settings.OCR_ENGINE
    if mode != "auto":
        effective_engine = mode

    logger.info(f"Running OCR on: {resolved} (mode={mode}, engine={effective_engine})")

    warnings: List[str] = []

    # ── VL-only mode: attempt enhanced OCR, return early if successful ──
    if effective_engine == "vl":
        vl_result = _try_vl_fallback(resolved)
        if vl_result:
            vl_markdown, _ = vl_result
            # We still need lines for confidence + structured output
            engine = _get_engine()
            result = engine.ocr(resolved)
            lines = _paddle_result_to_lines(result)
            avg_confidence = (
                sum(line.confidence for line in lines) / len(lines) if lines else 0.0
            )
            return OcrScanResponse(
                engine="paddleocr-enhanced",
                rawText="\n".join(line.text for line in lines),
                confidence=round(avg_confidence, 4),
                lines=lines,
                markdown=vl_markdown,
                documentJson=None,
                usedVl=True,
                warnings=warnings,
            )
        else:
            warnings.append("Enhanced OCR requested but unavailable; falling back to ppocr")

    # ── Standard ppocr path ──
    engine = _get_engine()
    result = engine.ocr(resolved)
    lines = _paddle_result_to_lines(result)

    raw_text = "\n".join(line.text for line in lines)
    avg_confidence = (
        sum(line.confidence for line in lines) / len(lines) if lines else 0.0
    )

    # ── Auto-fallback: try enhanced OCR if confidence is low ──
    used_enhanced = False
    vl_markdown: Optional[str] = None
    threshold = settings.OCR_MIN_CONFIDENCE
    if (
        effective_engine in ("auto", "ppocr")
        and settings.ENABLE_PADDLEOCR_VL
        and avg_confidence < threshold
        and lines
    ):
        logger.warning(
            f"Low confidence ({avg_confidence:.2f} < {threshold}), attempting enhanced fallback"
        )
        vl_result = _try_vl_fallback(resolved)
        if vl_result:
            vl_markdown, _ = vl_result
            used_enhanced = True
        else:
            warnings.append(
                f"Low OCR confidence ({avg_confidence:.2f}); enhanced fallback unavailable"
            )

    markdown = vl_markdown if used_enhanced and vl_markdown else _build_markdown(lines)

    return OcrScanResponse(
        engine="paddleocr-enhanced" if used_enhanced else "paddleocr-pp-ocrv5",
        rawText=raw_text,
        confidence=round(avg_confidence, 4),
        lines=lines,
        markdown=markdown,
        documentJson=None,
        usedVl=used_enhanced,
        warnings=warnings,
    )


def _build_markdown(lines: List[OcrLine]) -> str:
    if not lines:
        return ""
    sorted_lines = sorted(lines, key=lambda l: l.box.y1)
    return "\n".join(f"{line.text}" for line in sorted_lines)
