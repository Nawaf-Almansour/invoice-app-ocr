from app.core.config import settings

app = FastAPI(title="Invoice OCR Worker", version="1.0.0")

app.add_middleware(
    CORSMiddleware,
    allow_origins=["*"],
    allow_methods=["*"],
    allow_headers=["*"],
)

app.include_router(ocr.router, prefix="/api/v1")


@app.get("/health")
def health():
    return {"status": "ok", "service": "ocr-worker"}
</file>

