  @Column({ length: 20, default: 'POSTED' })
  status: string;

  @OneToMany(() => JournalEntryLine, (l) => l.entry, { cascade: true })
  lines: JournalEntryLine[];

  @CreateDateColumn({ name: 'created_at' })
  createdAt: Date;
}
